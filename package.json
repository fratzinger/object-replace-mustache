{
  "name": "object-replace-mustache",
  "version": "4.0.1",
  "description": "replace placeholders of an object with a view like you would use mustache.render for strings",
  "author": "fratzinger",
  "homepage": "https://github.com/fratzinger/object-replace-mustache",
  "repository": {
    "type": "git",
    "url": "https://github.com/fratzinger/object-replace-mustache"
  },
  "keywords": [
    "object",
    "replace",
    "mustache",
    "placeholder"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "src/**",
    "dist/**"
  ],
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsdown",
    "version": "pnpm run build",
    "release": "np",
    "test": "vitest run",
    "vitest": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint",
    "bench": "tsx bench/index.ts"
  },
  "dependencies": {
    "meriyah": "^7.1.0"
  },
  "devDependencies": {
    "@feathers-community/eslint-config": "^0.0.10",
    "@types/ejs": "^3.1.5",
    "@types/mustache": "^4.2.6",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "ejs": "^5.0.1",
    "eslint": "^10.1.0",
    "handlebars": "^4.7.9",
    "mustache": "^4.2.0",
    "np": "^11.0.2",
    "pkg-pr-new": "^0.0.66",
    "shx": "^0.4.0",
    "tinybench": "^6.0.0",
    "tsdown": "^0.21.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
